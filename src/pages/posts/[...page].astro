---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import BaseItemCard from "../../components/ui/BaseItemCard.astro";
import { getListingItem } from "../../utils/adapters";
import { SITE, PAGES } from "../../config";

if (PAGES.blog.isActive === false) {
    return Astro.redirect("/404");
}

export async function getStaticPaths({ paginate }: any) {
    if (PAGES.blog.isActive === false) return [];
    const posts = await getCollection("posts");
    const sortedPosts = posts.sort(
        (a: any, b: any) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
    );

    return paginate(sortedPosts, { pageSize: SITE.postPerPage });
}

const { page } = Astro.props;
const groupedPosts = page.data.reduce((groups: Record<string, any[]>, post: any) => {
    const category = post.data.category || "Technical";
    groups[category] = groups[category] || [];
    groups[category].push(post);
    return groups;
}, {});
const categoryOrder = ["Technical", "Reflections"];
const categories = [
    ...categoryOrder.filter((category) => groupedPosts[category]),
    ...Object.keys(groupedPosts).filter((category) => !categoryOrder.includes(category)),
];
---

<BaseLayout title={PAGES.blog.title}>
    <header class="page-header">
        <h1 class="page-title">{PAGES.blog.title}</h1>
        <p class="page-subtitle">{PAGES.blog.subtitle}</p>
    </header>

    {
        categories.map((category) => (
            <section class="section">
                <h2 class="section-title border-b border-border pb-2">
                    {category}
                </h2>
                <div class="item-list">
                    {groupedPosts[category].map((post: any) => {
                        const item = getListingItem(post, "posts");
                        return <BaseItemCard {...item} href={`/posts/${post.id}`} />;
                    })}
                </div>
            </section>
        ))
    }

    {page.lastPage > 1 && (
        <nav class="pagination">
            {page.url.prev ? (
                <a href={page.url.prev} class="pagination-link">Newer</a>
            ) : (
                <span class="pagination-inactive">Newer</span>
            )}
            <span class="pagination-info">Page {page.currentPage} of {page.lastPage}</span>
            {page.url.next ? (
                <a href={page.url.next} class="pagination-link">Older</a>
            ) : (
                <span class="pagination-inactive">Older</span>
            )}
        </nav>
    )}
</BaseLayout>
