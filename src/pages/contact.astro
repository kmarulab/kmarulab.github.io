---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Contact">
    <div class="container-narrow">
        <header class="page-header">
            <h1 class="page-title">Contact</h1>
            <p class="page-subtitle">
                Send a note about research, consulting, projects, or collaboration.
            </p>
        </header>

        <div class="prose">
            <p>
                Messages submitted here are routed to
                <a href="mailto:emkboruett@gmail.com">emkboruett@gmail.com</a>.
                You can also email me directly at that address.
            </p>
        </div>

        <form
            class="mt-8 flex flex-col gap-4"
            action="https://formsubmit.co/126c168e28b21f31ee7b0212bb7f574b"
            method="POST"
        >
            <input type="hidden" name="_subject" value="New portfolio contact message" />
            <input type="hidden" name="_template" value="table" />
            <input type="hidden" name="_captcha" value="false" />
            <input type="hidden" name="_next" value="https://kmarulab.github.io/contact/?sent=1" />

            <label class="flex flex-col gap-2">
                <span class="body-sm font-semibold">Name</span>
                <input
                    class="w-full rounded-md border border-border bg-surface px-3 py-2 text-foreground outline-none focus:border-accent"
                    type="text"
                    name="name"
                    autocomplete="name"
                    required
                />
            </label>

            <label class="flex flex-col gap-2">
                <span class="body-sm font-semibold">Email</span>
                <input
                    class="w-full rounded-md border border-border bg-surface px-3 py-2 text-foreground outline-none focus:border-accent"
                    type="email"
                    name="email"
                    autocomplete="email"
                    required
                />
            </label>

            <label class="flex flex-col gap-2">
                <span class="body-sm font-semibold">Message</span>
                <textarea
                    class="min-h-40 w-full rounded-md border border-border bg-surface px-3 py-2 text-foreground outline-none focus:border-accent"
                    name="message"
                    required
                ></textarea>
            </label>

            <button class="card-link self-start" type="submit">
                Send Message
            </button>
        </form>

        <p class="body-sm text-text-muted mt-6">
            The first FormSubmit message may require confirming the email endpoint once.
        </p>
    </div>
</BaseLayout>
